{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy to .claude/settings.local.json (gitignored). Personal/machine overrides — never commit.",
  "model": "sonnet",
  "outputStyle": "senior-mentor",
  "env": {
    "EDITOR": "code",
    "CLAUDE_SESSION_BUDGET_USD": "0.50"
  },
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(make:*)"
    ]
  }
}
